# Template file for 'hyprlock-nightly'
pkgname=hyprlock-nightly
version=0.3.0
revision=1
build_style=cmake
hostmakedepends="cmake git pkgconf"
makedepends="cairo-devel hyprlang-nightly libdrm-devel libxkbcommon-devel MesaLib-devel pango-devel pam-devel wayland-devel wayland-protocols"
short_desc="Hyprland's GPU-accelerated screen locking utility"
maintainer="Makrennel <makrommel@protonmail.ch>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprlock"
changelog="https://github.com/hyprwm/${pkgname}/releases"

conflicts="hyprlock"

do_fetch() {
	git clone --depth=1 https://github.com/hyprwm/hyprlock.git $wrksrc
	cd $wrksrc
	version+=".t$(git show -s --format=%ct)"
}

post_install() {
	vlicense LICENSE
}

